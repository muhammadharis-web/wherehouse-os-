# Database
DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/fulfillment

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT
JWT_SECRET=your-secret-key-here

# OpenAI
OPENAI_API_KEY=sk-...

# Shipping APIs
EASYPOST_API_KEY=EZ...
SMARTYSTREETS_AUTH_ID=...
SMARTYSTREETS_AUTH_TOKEN=...

# Notifications
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
SENDGRID_API_KEY=SG...

# PostgreSQL (for docker-compose.prod.yml)
POSTGRES_DB=fulfillment
POSTGRES_USER=fulfillment
POSTGRES_PASSWORD=change-this-password
